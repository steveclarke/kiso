#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

# Catppuccin color palette (Latte variant)
ROSEWATER="220"
FLAMINGO="211"
PINK="217"
MAUVE="183"
LAVENDER="147"
BLUE="117"
GREEN="151"
YELLOW="222"
PEACH="216"
RED="210"
BORDER="147"

DRY_RUN=false
SKIP_CONFIRMATION=false
NPM_RELEASE=false

REPO_URL="https://github.com/steveclarke/kiso"

# ---------------------------------------------------------------------------
# Gum
# ---------------------------------------------------------------------------

ensure_gum_installed() {
  if ! command -v gum &>/dev/null; then
    echo "Charm's Gum is not installed. Would you like to install it now? (y/n)"
    read -r install_gum
    if [[ "$install_gum" =~ ^[Yy]$ ]]; then
      echo "Installing Charm's Gum..."
      if [[ "$OSTYPE" == "darwin"* ]]; then
        brew install gum
      elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        if command -v apt-get &>/dev/null; then
          sudo mkdir -p /etc/apt/keyrings
          curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
          echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list
          sudo apt update && sudo apt install gum
        elif command -v brew &>/dev/null; then
          brew install gum
        else
          echo "Unsupported Linux distribution. Please install Gum manually: https://github.com/charmbracelet/gum#installation"
          exit 1
        fi
      else
        echo "Unsupported operating system. Please install Gum manually: https://github.com/charmbracelet/gum#installation"
        exit 1
      fi

      if ! command -v gum &>/dev/null; then
        echo "Failed to install Gum. Please install it manually: https://github.com/charmbracelet/gum#installation"
        exit 1
      fi

      echo "Gum installed successfully!"
    else
      echo "Gum is required for this script. Exiting."
      exit 1
    fi
  fi
}

ensure_gum_installed

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  local exit_code=${1:-0}
  gum style --border normal --padding "1 2" --border-foreground "$BORDER" "
  $(gum style --foreground "$ROSEWATER" 'Kiso Release')

  $(gum style --bold 'Usage:') bin/release [OPTIONS] [VERSION]
  Prepare and tag a new release of kiso (gem, npm, or both).

  $(gum style --foreground "$MAUVE" --bold 'Arguments:')
    VERSION           Gem version to release (e.g. 0.1.0, 1.0.0)
                      If omitted, you'll be prompted interactively.

  $(gum style --foreground "$MAUVE" --bold 'Options:')
    -h, --help        Show this help message
    -n, --dry-run     Run preflight checks without committing or tagging
    -y, --yes         Skip confirmation prompt
    --npm [VERSION]   Release npm package kiso-ui (optionally with VERSION)
                      Use alone for npm-only, or with VERSION for both.

  $(gum style --foreground "$MAUVE" --bold 'Gem release steps:')
    1. Preflight checks (clean tree, on master, synced with origin)
    2. Run full test suite and linter
    3. Check CHANGELOG.md has unreleased entries
    4. Bump version in lib/kiso/version.rb
    5. Update CHANGELOG.md (move Unreleased → version heading)
    6. Verify gem builds
    7. Commit version bump and create annotated tag (v*)
    8. Push to origin and create GitHub Release

  $(gum style --foreground "$MAUVE" --bold 'npm release steps:')
    1. Preflight checks (clean tree, on master, synced with origin)
    2. Bump version in package.json
    3. Commit version bump and create annotated tag (npm-v*)
    4. Push to origin (GitHub Actions publishes to npm)

  $(gum style --foreground "$FLAMINGO" --bold 'Examples:')
    bin/release 0.1.0              # release gem 0.1.0
    bin/release --npm 0.1.1        # release npm 0.1.1
    bin/release 0.2.0 --npm 0.1.1  # release both
    bin/release --dry-run          # dry-run gem checks
    bin/release --dry-run --npm    # dry-run npm checks
    bin/release                    # interactive prompt for gem version
  "
  exit "$exit_code"
}

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------

NEW_VERSION=""
NPM_VERSION=""
ARGS=("$@")

i=0
while [ $i -lt ${#ARGS[@]} ]; do
  arg="${ARGS[$i]}"
  case "$arg" in
    -h|--help) usage 0 ;;
    -n|--dry-run) DRY_RUN=true ;;
    -y|--yes) SKIP_CONFIRMATION=true ;;
    --npm)
      NPM_RELEASE=true
      # Consume next arg as npm version if it doesn't start with -
      if [ $((i + 1)) -lt ${#ARGS[@]} ] && [[ "${ARGS[$((i + 1))]}" != -* ]]; then
        i=$((i + 1))
        NPM_VERSION="${ARGS[$i]}"
      fi
      ;;
    -*)
      gum style --foreground "$RED" "✗ Unknown option: $arg (see --help)"
      exit 1
      ;;
    *) NEW_VERSION="$arg" ;;
  esac
  i=$((i + 1))
done

# Determine release modes
GEM_RELEASE=false
if [ -n "$NEW_VERSION" ] || [ "$NPM_RELEASE" = false ]; then
  GEM_RELEASE=true
fi

# ---------------------------------------------------------------------------
# Read current versions
# ---------------------------------------------------------------------------

if [ "$GEM_RELEASE" = true ]; then
  CURRENT_VERSION=$(ruby -r ./lib/kiso/version -e 'puts Kiso::VERSION')
fi

if [ "$NPM_RELEASE" = true ]; then
  CURRENT_NPM_VERSION=$(node -p "require('./package.json').version")
fi

# ---------------------------------------------------------------------------
# Determine new versions
# ---------------------------------------------------------------------------

if [ "$GEM_RELEASE" = true ]; then
  if [ -z "$NEW_VERSION" ]; then
    if [[ "$SKIP_CONFIRMATION" == "true" ]]; then
      gum style --foreground "$RED" "✗ Gem version required when using -y (e.g. bin/release -y 0.2.0)"
      exit 1
    fi
    gum style --foreground "$BLUE" "Current gem version: $(gum style --bold "$CURRENT_VERSION")"
    echo ""
    NEW_VERSION=$(gum input --placeholder "0.x.0" --prompt "$(gum style --foreground "$MAUVE" "New gem version: ")" --value "$CURRENT_VERSION")
  fi

  if [ -z "$NEW_VERSION" ]; then
    gum style --foreground "$RED" "✗ Gem version cannot be empty"
    exit 1
  fi

  TAG="v${NEW_VERSION}"
  TODAY=$(date +%Y-%m-%d)
fi

if [ "$NPM_RELEASE" = true ]; then
  if [ -z "$NPM_VERSION" ]; then
    if [[ "$SKIP_CONFIRMATION" == "true" ]]; then
      gum style --foreground "$RED" "✗ npm version required when using -y (e.g. bin/release -y --npm 0.1.1)"
      exit 1
    fi
    gum style --foreground "$BLUE" "Current npm version: $(gum style --bold "$CURRENT_NPM_VERSION")"
    echo ""
    NPM_VERSION=$(gum input --placeholder "0.x.0" --prompt "$(gum style --foreground "$MAUVE" "New npm version: ")" --value "$CURRENT_NPM_VERSION")
  fi

  if [ -z "$NPM_VERSION" ]; then
    gum style --foreground "$RED" "✗ npm version cannot be empty"
    exit 1
  fi

  NPM_TAG="npm-v${NPM_VERSION}"
fi

# ---------------------------------------------------------------------------
# Preflight checks
# ---------------------------------------------------------------------------

gum style --foreground "$LAVENDER" --bold "\nPreflight checks"

# Clean working tree?
if [ -n "$(git status --porcelain)" ]; then
  gum style --foreground "$RED" "✗ Working tree is not clean. Commit or stash changes first."
  exit 1
fi
gum style --foreground "$GREEN" "✓ Working tree clean"

# On master branch?
BRANCH=$(git branch --show-current)
if [ "$BRANCH" != "master" ]; then
  gum style --foreground "$RED" "✗ Not on master branch (on ${BRANCH}). Switch to master first."
  exit 1
fi
gum style --foreground "$GREEN" "✓ On master branch"

# Up to date with remote?
gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Fetching from origin...")" -- \
  git fetch origin --quiet
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/master)
if [ "$LOCAL" != "$REMOTE" ]; then
  gum style --foreground "$RED" "✗ Local master is not up to date with origin. Pull first."
  exit 1
fi
gum style --foreground "$GREEN" "✓ Up to date with origin/master"

# Gem-specific preflight
if [ "$GEM_RELEASE" = true ]; then
  # Tag doesn't already exist?
  if git rev-parse "$TAG" >/dev/null 2>&1; then
    gum style --foreground "$RED" "✗ Tag ${TAG} already exists"
    exit 1
  fi
  gum style --foreground "$GREEN" "✓ Tag ${TAG} is available"

  # gh CLI available?
  if ! command -v gh &>/dev/null; then
    gum style --foreground "$RED" "✗ gh CLI not found. Install it: https://cli.github.com"
    exit 1
  fi
  gum style --foreground "$GREEN" "✓ gh CLI available"

  # CHANGELOG.md has unreleased entries?
  UNRELEASED_CONTENT=$(sed -n '/^## \[Unreleased\]/,/^## \[/{/^## \[/!p;}' CHANGELOG.md | sed '/^$/d')
  if [ -z "$UNRELEASED_CONTENT" ]; then
    gum style --foreground "$RED" "✗ CHANGELOG.md has no entries under [Unreleased]. Add changes before releasing."
    exit 1
  fi
  gum style --foreground "$GREEN" "✓ CHANGELOG.md has unreleased entries"
fi

# npm-specific preflight
if [ "$NPM_RELEASE" = true ]; then
  # npm CLI available?
  if ! command -v npm &>/dev/null; then
    gum style --foreground "$RED" "✗ npm CLI not found"
    exit 1
  fi
  gum style --foreground "$GREEN" "✓ npm CLI available"

  # npm tag doesn't already exist?
  if git rev-parse "$NPM_TAG" >/dev/null 2>&1; then
    gum style --foreground "$RED" "✗ Tag ${NPM_TAG} already exists"
    exit 1
  fi
  gum style --foreground "$GREEN" "✓ Tag ${NPM_TAG} is available"
fi

# ---------------------------------------------------------------------------
# Tests and linter (gem releases only)
# ---------------------------------------------------------------------------

if [ "$GEM_RELEASE" = true ]; then
  gum style --foreground "$LAVENDER" --bold "\nRunning tests and linter"

  gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Running test suite...")" -- \
    bundle exec rake test
  gum style --foreground "$GREEN" "✓ All tests pass"

  gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Running StandardRB...")" -- \
    bundle exec standardrb
  gum style --foreground "$GREEN" "✓ StandardRB clean"
fi

# ---------------------------------------------------------------------------
# Dry run exit
# ---------------------------------------------------------------------------

if [ "$DRY_RUN" = true ]; then
  DRY_RUN_LINES=""

  if [ "$GEM_RELEASE" = true ]; then
    DRY_RUN_LINES+="$(gum style --foreground "$BLUE" "Current gem version: $(gum style --bold "$CURRENT_VERSION")")
$(gum style --foreground "$BLUE" "New gem version:     $(gum style --bold "$NEW_VERSION")")
$(gum style --foreground "$BLUE" "Gem tag:             $(gum style --bold "$TAG")")
"
  fi

  if [ "$NPM_RELEASE" = true ]; then
    DRY_RUN_LINES+="$(gum style --foreground "$BLUE" "Current npm version: $(gum style --bold "$CURRENT_NPM_VERSION")")
$(gum style --foreground "$BLUE" "New npm version:     $(gum style --bold "$NPM_VERSION")")
$(gum style --foreground "$BLUE" "npm tag:             $(gum style --bold "$NPM_TAG")")
"
  fi

  CHANGELOG_SECTION=""
  if [ "$GEM_RELEASE" = true ]; then
    CHANGELOG_SECTION="
$(gum style --foreground "$MAUVE" --bold "Unreleased changelog entries:")
$UNRELEASED_CONTENT
"
  fi

  gum style --border double --padding "1 2" --border-foreground "$YELLOW" "
$(gum style --foreground "$YELLOW" --bold "Dry run complete — no changes made.")
${DRY_RUN_LINES}${CHANGELOG_SECTION}
All checks passed. Run without --dry-run to commit and tag.
"
  exit 0
fi

# ---------------------------------------------------------------------------
# Confirm before making changes
# ---------------------------------------------------------------------------

CONFIRM_MSG=""
if [ "$GEM_RELEASE" = true ] && [ "$NPM_RELEASE" = true ]; then
  gum style --foreground "$LAVENDER" "Gem version: $(gum style --bold --foreground "$GREEN" "$NEW_VERSION")  npm version: $(gum style --bold --foreground "$GREEN" "$NPM_VERSION")"
  CONFIRM_MSG="Bump gem to $TAG + npm to $NPM_TAG, commit, and tag?"
elif [ "$GEM_RELEASE" = true ]; then
  gum style --foreground "$LAVENDER" "Version will be: $(gum style --bold --foreground "$GREEN" "$NEW_VERSION")"
  CONFIRM_MSG="Bump to $TAG, commit, and tag?"
else
  gum style --foreground "$LAVENDER" "npm version will be: $(gum style --bold --foreground "$GREEN" "$NPM_VERSION")"
  CONFIRM_MSG="Bump npm to $NPM_TAG, commit, and tag?"
fi

if [[ "$SKIP_CONFIRMATION" != "true" ]]; then
  if ! gum confirm --prompt.foreground "$MAUVE" "$CONFIRM_MSG"; then
    gum style --foreground "$YELLOW" "Aborting release."
    exit 0
  fi
fi

# ---------------------------------------------------------------------------
# Bump gem version
# ---------------------------------------------------------------------------

if [ "$GEM_RELEASE" = true ]; then
  gum style --foreground "$LAVENDER" --bold "\nBumping gem version to ${NEW_VERSION}"

  gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Updating lib/kiso/version.rb...")" -- \
    bash -c "sed -i '' \"s/VERSION = \\\".*\\\"/VERSION = \\\"${NEW_VERSION}\\\"/\" lib/kiso/version.rb"
  gum style --foreground "$GREEN" "✓ Updated lib/kiso/version.rb"

  # Update CHANGELOG
  gum style --foreground "$LAVENDER" --bold "\nUpdating CHANGELOG.md"

  NEW_LINKS="[Unreleased]: ${REPO_URL}/compare/${TAG}...HEAD"
  VERSION_LINK="[${NEW_VERSION}]: ${REPO_URL}/releases/tag/${TAG}"

  sed -i '' "s/^## \[Unreleased\]$/## [Unreleased]\n\n## [${NEW_VERSION}] - ${TODAY}/" CHANGELOG.md
  sed -i '' "s|^\[Unreleased\]:.*|${NEW_LINKS}\n${VERSION_LINK}|" CHANGELOG.md

  gum style --foreground "$GREEN" "✓ Updated CHANGELOG.md"

  # Verify gem builds
  gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Verifying gem builds...")" -- \
    bash -c "gem build kiso.gemspec --silent && rm -f kiso-*.gem"
  gum style --foreground "$GREEN" "✓ Gem builds successfully"
fi

# ---------------------------------------------------------------------------
# Bump npm version
# ---------------------------------------------------------------------------

if [ "$NPM_RELEASE" = true ]; then
  gum style --foreground "$LAVENDER" --bold "\nBumping npm version to ${NPM_VERSION}"

  gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Updating package.json...")" -- \
    npm version "$NPM_VERSION" --no-git-tag-version
  gum style --foreground "$GREEN" "✓ Updated package.json"
fi

# ---------------------------------------------------------------------------
# Commit and tag
# ---------------------------------------------------------------------------

# Build file list and commit message
GIT_ADD_FILES=""
COMMIT_MSG=""

if [ "$GEM_RELEASE" = true ] && [ "$NPM_RELEASE" = true ]; then
  GIT_ADD_FILES="lib/kiso/version.rb CHANGELOG.md package.json"
  COMMIT_MSG="Release v${NEW_VERSION} + kiso-ui npm-v${NPM_VERSION}"
elif [ "$GEM_RELEASE" = true ]; then
  GIT_ADD_FILES="lib/kiso/version.rb CHANGELOG.md"
  COMMIT_MSG="Release v${NEW_VERSION}"
else
  GIT_ADD_FILES="package.json"
  COMMIT_MSG="Release kiso-ui npm-v${NPM_VERSION}"
fi

gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Committing release...")" -- \
  bash -c "git add ${GIT_ADD_FILES} && git commit -m '${COMMIT_MSG}'"
gum style --foreground "$GREEN" "✓ Committed release"

# Create tags
if [ "$GEM_RELEASE" = true ]; then
  gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Tagging ${TAG}...")" -- \
    git tag -a "$TAG" -m "Release ${NEW_VERSION}"
  gum style --foreground "$GREEN" "✓ Tagged ${TAG}"
fi

if [ "$NPM_RELEASE" = true ]; then
  gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Tagging ${NPM_TAG}...")" -- \
    git tag -a "$NPM_TAG" -m "Release kiso-ui ${NPM_VERSION}"
  gum style --foreground "$GREEN" "✓ Tagged ${NPM_TAG}"
fi

# ---------------------------------------------------------------------------
# Push and GitHub Release
# ---------------------------------------------------------------------------

gum style --foreground "$LAVENDER" --bold "\nPushing to origin"

# Build push command with all tags
PUSH_REFS="master"
if [ "$GEM_RELEASE" = true ]; then PUSH_REFS+=" $TAG"; fi
if [ "$NPM_RELEASE" = true ]; then PUSH_REFS+=" $NPM_TAG"; fi

gum spin --spinner points --title "$(gum style --foreground "$BLUE" "Pushing commit and tags...")" -- \
  bash -c "git push origin ${PUSH_REFS}"
gum style --foreground "$GREEN" "✓ Pushed commit and tags"

# GitHub Release (gem releases only)
if [ "$GEM_RELEASE" = true ]; then
  gum style --foreground "$LAVENDER" --bold "\nCreating GitHub Release"

  RELEASE_NOTES=$(sed -n "/^## \[${NEW_VERSION}\]/,/^## \[/{/^## \[/!p;}" CHANGELOG.md | sed -e '/^$/d' -e '1{/^$/d;}' -e '${/^$/d;}')

  if [[ "$NEW_VERSION" == *pre* || "$NEW_VERSION" == *alpha* || "$NEW_VERSION" == *beta* || "$NEW_VERSION" == *rc* ]]; then
    gh release create "$TAG" --title "$TAG" --notes "$RELEASE_NOTES" --prerelease
  else
    gh release create "$TAG" --title "$TAG" --notes "$RELEASE_NOTES"
  fi
  gum style --foreground "$GREEN" "✓ GitHub Release created"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

SHORT_SHA=$(git rev-parse --short HEAD)

SUMMARY_LINES=""
if [ "$GEM_RELEASE" = true ]; then
  SUMMARY_LINES+="$(gum style --foreground "$BLUE" "Version: $(gum style --bold "$NEW_VERSION")")
$(gum style --foreground "$BLUE" "Tag:     $(gum style --bold "$TAG")")
"
fi
if [ "$NPM_RELEASE" = true ]; then
  SUMMARY_LINES+="$(gum style --foreground "$BLUE" "npm:     $(gum style --bold "kiso-ui@${NPM_VERSION}")")
$(gum style --foreground "$BLUE" "npm tag: $(gum style --bold "$NPM_TAG")")
"
fi
SUMMARY_LINES+="$(gum style --foreground "$BLUE" "Commit:  $(gum style --bold "$SHORT_SHA")")"

ACTIONS_MSG=""
if [ "$GEM_RELEASE" = true ]; then
  SUMMARY_LINES+="
$(gum style --foreground "$BLUE" "Release: ${REPO_URL}/releases/tag/${TAG}")"
  ACTIONS_MSG+="GitHub Actions will push the gem to RubyGems."
fi
if [ "$NPM_RELEASE" = true ]; then
  if [ -n "$ACTIONS_MSG" ]; then ACTIONS_MSG+=$'\n'; fi
  ACTIONS_MSG+="GitHub Actions will push kiso-ui to npm."
fi

gum style --border double --padding "1 2" --border-foreground "$GREEN" "
$(gum style --foreground "$GREEN" --bold "Release complete!")
${SUMMARY_LINES}

${ACTIONS_MSG}
"
