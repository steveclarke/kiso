#!/usr/bin/env bash
set -euo pipefail

################################################################################
# bin/dev — Development process manager
################################################################################
#
# OVERVIEW
# --------
# Starts, stops, and manages development services via Overmind.
# Wraps overmind with sensible defaults and a friendlier interface.
#
# USAGE
# -----
#   bin/dev                 Start all services (daemonized)
#   bin/dev -f              Start all services (foreground)
#   bin/dev stop            Stop a running instance
#   bin/dev restart web     Restart a specific service
#   bin/dev status          Show process statuses
#   bin/dev logs            Tail logs from all services
#   bin/dev logs web        Tail logs from a specific service
#   bin/dev -- -l web,css   Pass flags directly to overmind
#
# CONFIGURATION
# -------------
# Services are defined in Procfile.dev. Settings in .overmind.env:
#   OVERMIND_SOCKET    — socket path (default: tmp/overmind.sock)
#   OVERMIND_NO_PORT   — disable auto port assignment
#   OVERMIND_CAN_DIE   — processes allowed to exit without killing others
#
################################################################################

# Configuration
PROCFILE="Procfile.dev"
SOCKET="tmp/overmind.sock"

################################################################################
# Main Orchestration
################################################################################

main() {
  require_overmind
  mkdir -p tmp

  case "${1:-start}" in
    start)   shift 2>/dev/null || true; cmd_start "$@" ;;
    stop)    cmd_stop ;;
    restart) shift; cmd_restart "$@" ;;
    status)  cmd_status ;;
    logs)    shift 2>/dev/null || true; cmd_logs "$@" ;;
    help|-h|--help) usage ;;
    -f)      cmd_start "$@" ;;
    --)      shift; cmd_start -- "$@" ;;
    *)       usage; exit 1 ;;
  esac
}

################################################################################
# Helper Functions
################################################################################

red='\033[0;31m'
nc='\033[0m'

error() { echo -e "${red}Error:${nc} ${1}" >&2; exit 1; }

require_overmind() {
  command -v overmind > /dev/null 2>&1 \
    || error "overmind is not installed. Run bin/setup to install."
}

is_running() {
  [ -e "$SOCKET" ] && overmind status -s "$SOCKET" > /dev/null 2>&1
}

require_running() {
  is_running || error "Overmind is not running. Start it with: bin/dev"
}

cleanup_stale_socket() {
  if [ -e "$SOCKET" ] && ! overmind status -s "$SOCKET" > /dev/null 2>&1; then
    rm -f "$SOCKET"
  fi
}

print_urls() {
  echo ""
  echo "  Lookbook → http://localhost:${LOOKBOOK_PORT:-4001}"
  echo "  Docs     → http://localhost:${DOCS_PORT:-4000}"
}

usage() {
  cat <<EOF
Usage: bin/dev [command] [options]

Commands:
  start            Start all services daemonized (default)
  stop             Stop a running instance
  restart [NAME]   Restart a service (auto-starts if not running)
  status           Show process statuses and URLs
  logs [NAME]      Tail logs (all services, or a specific one)
  help             Show this help message

Options:
  -f               Start in foreground (instead of daemonized)
  --               Pass remaining args directly to overmind

Examples:
  bin/dev                 Start daemonized
  bin/dev -f              Start in foreground
  bin/dev stop            Stop daemonized instance
  bin/dev restart web     Restart the web process
  bin/dev restart docs    Restart the docs process
  bin/dev status          Show running processes and URLs
  bin/dev logs            Tail all logs
  bin/dev logs web        Tail logs from the web process only
  bin/dev -- -l web,css   Pass flags directly to overmind
EOF
}

################################################################################
# Commands
################################################################################

cmd_start() {
  local foreground=false
  local passthrough=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f) foreground=true; shift ;;
      --)  shift; passthrough+=("$@"); break ;;
      *)   passthrough+=("$1"); shift ;;
    esac
  done

  cleanup_stale_socket

  if is_running; then
    echo "Overmind is already running."
    cmd_status
    return
  fi

  if $foreground; then
    exec overmind start -f "$PROCFILE" -s "$SOCKET" "${passthrough[@]+"${passthrough[@]}"}"
  else
    overmind start -f "$PROCFILE" -s "$SOCKET" -D "${passthrough[@]+"${passthrough[@]}"}"
    sleep 1
    cmd_status
  fi
}

cmd_stop() {
  if ! is_running; then
    cleanup_stale_socket
    error "Overmind is not running."
  fi
  overmind quit -s "$SOCKET" 2>/dev/null || rm -f "$SOCKET"
  echo "Stopped."
}

cmd_restart() {
  if ! is_running; then
    cleanup_stale_socket
    echo "Overmind not running — starting daemonized..."
    overmind start -f "$PROCFILE" -s "$SOCKET" -D
    sleep 1
  fi
  overmind restart -s "$SOCKET" "$@"
}

cmd_status() {
  require_running
  overmind status -s "$SOCKET"
  print_urls
}

cmd_logs() {
  require_running
  if [[ $# -gt 0 ]]; then
    exec overmind echo -s "$SOCKET" "$1"
  else
    exec overmind echo -s "$SOCKET"
  fi
}

################################################################################
# Script Execution
################################################################################

main "$@"
