#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "kiso/version"
require "kiso/cli"

begin
  Kiso::Cli::Main.start(ARGV)
rescue => e
  warn "  \e[31mERROR: #{e.message}\e[0m"
  warn e.backtrace.join("\n") if ENV["VERBOSE"]
  exit 1
end
