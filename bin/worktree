#!/usr/bin/env bash
set -euo pipefail

################################################################################
# bin/worktree — Worktree port management for parallel development
################################################################################
#
# Assigns deterministic Lookbook and docs ports to git worktrees so multiple
# agents can develop components in parallel without port conflicts.
#
# USAGE
# -----
#   bin/worktree port             Ports for current worktree
#   bin/worktree port <name>      Ports for named worktree
#   bin/worktree env              Export lines for current worktree
#   bin/worktree start            Start Lookbook + Tailwind + docs on assigned ports
#   bin/worktree start --no-docs  Start Lookbook + Tailwind only (skip docs)
#   bin/worktree stop             Stop services in current worktree
#   bin/worktree status           Show running services
#
# PORT FORMULA
# ------------
# Main worktree → Lookbook 4001, docs 4000 (defaults)
# Named worktrees → Lookbook 4101–4600, docs 4601–5100 (MD5 hash)
#
# INTEGRATION
# -----------
# Agents use this to start isolated instances:
#
#   eval $(bin/worktree env)
#   bin/dev -- -l web,css
#
# Or simply:
#
#   bin/worktree start
#
################################################################################

LOOKBOOK_MAIN_PORT=4001
LOOKBOOK_PORT_BASE=4101
DOCS_MAIN_PORT=4000
DOCS_PORT_BASE=4601
PORT_RANGE=500

################################################################################
# Port Calculation
################################################################################

# Returns the worktree name (directory basename) or "main" for the primary checkout
worktree_name() {
  local name="${1:-}"

  if [ -n "$name" ]; then
    echo "$name"
    return
  fi

  # Detect if we're in a worktree
  local git_dir
  git_dir=$(git rev-parse --git-dir 2>/dev/null)

  if [[ "$git_dir" == *".git/worktrees/"* ]]; then
    # We're in a worktree — extract name from path
    basename "$(git rev-parse --show-toplevel)"
  else
    echo "main"
  fi
}

# Deterministic port offset from worktree name using MD5 hash
hash_offset() {
  local name="$1"
  local hash
  hash=$(echo -n "$name" | md5 -q 2>/dev/null || echo -n "$name" | md5sum | cut -d' ' -f1)
  echo $(( 16#${hash:0:8} % PORT_RANGE ))
}

# Calculate Lookbook port for a worktree
lookbook_port() {
  local name
  name=$(worktree_name "${1:-}")

  if [ "$name" = "main" ]; then
    echo "$LOOKBOOK_MAIN_PORT"
  else
    echo $(( LOOKBOOK_PORT_BASE + $(hash_offset "$name") ))
  fi
}

# Calculate docs port for a worktree
docs_port() {
  local name
  name=$(worktree_name "${1:-}")

  if [ "$name" = "main" ]; then
    echo "$DOCS_MAIN_PORT"
  else
    echo $(( DOCS_PORT_BASE + $(hash_offset "$name") ))
  fi
}

################################################################################
# Commands
################################################################################

cmd_port() {
  local filter="${1:-}"

  case "$filter" in
    lookbook) lookbook_port "${2:-}" ;;
    docs)     docs_port "${2:-}" ;;
    *)
      local lb_port docs_p
      lb_port=$(lookbook_port "${filter}")
      docs_p=$(docs_port "${filter}")
      echo "Lookbook: $lb_port"
      echo "Docs:     $docs_p"
      ;;
  esac
}

cmd_env() {
  local lb_port docs_p
  lb_port=$(lookbook_port "${1:-}")
  docs_p=$(docs_port "${1:-}")
  echo "export LOOKBOOK_PORT=$lb_port"
  echo "export DOCS_PORT=$docs_p"
}

cmd_start() {
  local lb_port docs_p
  lb_port=$(lookbook_port)
  docs_p=$(docs_port)

  local services="web,css,docs"
  if [ "${1:-}" = "--no-docs" ]; then
    services="web,css"
    echo "Starting Lookbook on port $lb_port..."
  else
    echo "Starting Lookbook on port $lb_port, docs on port $docs_p..."
  fi

  LOOKBOOK_PORT=$lb_port DOCS_PORT=$docs_p exec bin/dev -- -l "$services"
}

cmd_stop() {
  bin/dev stop
}

cmd_status() {
  bin/dev status 2>/dev/null || echo "Not running"
}

cmd_help() {
  cat <<EOF
Usage: bin/worktree <command> [name]

Commands:
  port [name]          Show both ports for current or named worktree
  port lookbook [name] Show Lookbook port only (for scripting)
  port docs [name]     Show docs port only (for scripting)
  env [name]           Print export lines for shell eval
  start                Start Lookbook + Tailwind + docs on assigned ports
  start --no-docs      Start Lookbook + Tailwind only (skip docs)
  stop                 Stop services
  status               Show running services
  help                 Show this help

Examples:
  bin/worktree port                    # → Lookbook: 4001, Docs: 4000 (main)
  bin/worktree port feat-input         # → Lookbook: 4237, Docs: 4737 (deterministic)
  bin/worktree port lookbook           # → 4001 (just the number, for scripting)
  bin/worktree port docs               # → 4000
  eval \$(bin/worktree env)             # Export LOOKBOOK_PORT + DOCS_PORT
  bin/worktree start                   # Start all on assigned ports
  bin/worktree start --no-docs         # Start Lookbook only
EOF
}

################################################################################
# Main
################################################################################

case "${1:-help}" in
  port)    shift; cmd_port "${1:-}" "${2:-}" ;;
  env)     shift; cmd_env "${1:-}" ;;
  start)   shift 2>/dev/null || true; cmd_start "${1:-}" ;;
  stop)    cmd_stop ;;
  status)  cmd_status ;;
  help|-h|--help) cmd_help ;;
  *)       cmd_help; exit 1 ;;
esac
