<h1 class="text-2xl font-bold tracking-tight">Dashboard</h1>
<p class="text-muted-foreground text-sm mt-1">Your approval requests will appear here.</p>

<%= kui(:separator, css_classes: "my-6") %>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <%= kui(:stats_card) do %>
    <%= kui(:stats_card, :header) { kui(:stats_card, :label) { "Pending" } } %>
    <%= kui(:stats_card, :value) { "12" } %>
  <% end %>
  <%= kui(:stats_card) do %>
    <%= kui(:stats_card, :header) { kui(:stats_card, :label) { "Approved" } } %>
    <%= kui(:stats_card, :value) { "84" } %>
  <% end %>
  <%= kui(:stats_card) do %>
    <%= kui(:stats_card, :header) { kui(:stats_card, :label) { "Rejected" } } %>
    <%= kui(:stats_card, :value) { "3" } %>
  <% end %>
</div>

<%= kui(:separator, css_classes: "my-6") %>

<%= kui(:alert, color: :info, variant: :soft) do %>
  <%= kui(:alert, :title) { "Smoke test" } %>
  <%= kui(:alert, :description) { "Full dashboard layout matching ApproveThis structure." } %>
<% end %>
