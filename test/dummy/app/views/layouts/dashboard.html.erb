<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <title><%= content_for(:title).presence || "Dashboard" %></title>
    <%= kiso_theme_script %>
    <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body>
    <%= kui(:dashboard_group) do %>
      <%= kui(:dashboard_navbar) do %>
        <%= kui(:dashboard_navbar, :toggle) %>
        <%= yield :topbar %>

        <%= kui(:color_mode_button) %>

        <%= yield :topbar_end %>
      <% end %>

      <%= kui(:dashboard_sidebar) do %>
        <%= yield :sidebar %>
      <% end %>

      <%= kui(:dashboard_panel) do %>
        <%= yield %>
      <% end %>
    <% end %>
  </body>
</html>
