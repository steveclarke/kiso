<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <title><%= content_for(:title).presence || "Dashboard" %></title>
    <%= kiso_theme_script %>
    <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body>
    <%= kui(:dashboard_group, sidebar_open: @sidebar_open) do %>
      <%= kui(:dashboard_navbar) do %>
        <%= kui(:dashboard_navbar, :toggle) %>
        <%= yield :topbar %>

        <%# Theme toggle — always in topbar, right side %>
        <button data-controller="kiso--theme"
                data-action="click->kiso--theme#toggle"
                aria-label="Toggle dark mode"
                class="flex items-center justify-center w-8 h-8 rounded-md text-foreground/50 hover:text-foreground hover:bg-accent transition-colors duration-150 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </button>

        <%= yield :topbar_end %>
      <% end %>

      <%= kui(:dashboard_sidebar) do %>
        <%= yield :sidebar %>
      <% end %>

      <%= kui(:dashboard_panel) do %>
        <%= yield %>
      <% end %>
    <% end %>
  </body>
</html>
