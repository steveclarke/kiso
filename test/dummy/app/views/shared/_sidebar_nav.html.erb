<%# Sidebar header: logo + app name %>
<div class="flex items-center gap-2.5 px-4 shrink-0 border-b border-[--sidebar-border]"
     style="height: var(--topbar-height)">

  <%# X close button — mobile only %>
  <button data-action="click->kiso--sidebar#toggle"
          aria-label="Close sidebar"
          class="md:hidden flex items-center justify-center w-7 h-7 rounded-md text-[--sidebar-foreground]/50 hover:text-[--sidebar-foreground] hover:bg-[--sidebar-accent] transition-colors duration-150 shrink-0 -ml-1 mr-0.5">
    <%= kiso_icon("x", class: "size-4") %>
  </button>

  <div class="flex items-center justify-center w-6 h-6 rounded-md bg-primary shrink-0">
    <%= kiso_icon("layers", class: "size-3.5 text-primary-foreground") %>
  </div>
  <span data-slot="nav-item-label" class="font-semibold text-sm text-[--sidebar-foreground] truncate">
    Kiso App
  </span>
</div>

<%# Navigation sections %>
<div class="flex-1 overflow-y-auto py-3 px-2 space-y-5">

  <%# Platform section %>
  <div data-slot="nav-section">
    <p data-slot="nav-section-title"
       class="px-3 mb-1 text-[11px] font-semibold uppercase tracking-widest text-[--sidebar-foreground]/40 truncate">
      Platform
    </p>

    <a href="/dashboard"
       data-slot="nav-item"
       aria-current="page"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              aria-[current=page]:bg-[--sidebar-accent] aria-[current=page]:text-primary
              transition-colors duration-150">
      <%= kiso_icon("layout-dashboard", class: "size-4 shrink-0 opacity-70 group-aria-[current=page]:opacity-100") %>
      <span data-slot="nav-item-label" class="truncate">Dashboard</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <%= kiso_icon("bar-chart-3", class: "size-4 shrink-0 opacity-70") %>
      <span data-slot="nav-item-label" class="truncate">Analytics</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <%= kiso_icon("folder", class: "size-4 shrink-0 opacity-70") %>
      <span data-slot="nav-item-label" class="truncate">Projects</span>
      <%= kui(:badge, color: :primary, variant: :soft, size: :sm) { "4" } %>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <%= kiso_icon("list-todo", class: "size-4 shrink-0 opacity-70") %>
      <span data-slot="nav-item-label" class="truncate">Tasks</span>
    </a>
  </div>

  <%# Manage section %>
  <div data-slot="nav-section">
    <p data-slot="nav-section-title"
       class="px-3 mb-1 text-[11px] font-semibold uppercase tracking-widest text-[--sidebar-foreground]/40 truncate">
      Manage
    </p>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <%= kiso_icon("users", class: "size-4 shrink-0 opacity-70") %>
      <span data-slot="nav-item-label" class="truncate">Team</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <%= kiso_icon("settings", class: "size-4 shrink-0 opacity-70") %>
      <span data-slot="nav-item-label" class="truncate">Settings</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <%= kiso_icon("credit-card", class: "size-4 shrink-0 opacity-70") %>
      <span data-slot="nav-item-label" class="truncate">Billing</span>
    </a>
  </div>
</div>

<%# Theme selector %>
<div class="shrink-0 px-4 py-3 border-t border-[--sidebar-border]">
  <p class="px-1 mb-1.5 text-[11px] font-semibold uppercase tracking-widest text-[--sidebar-foreground]/40">Theme</p>
  <%= kui(:color_mode_select, size: :sm) %>
</div>

<%# Sidebar footer: user profile %>
<div class="shrink-0 p-3 border-t border-[--sidebar-border]">
  <div class="flex items-center gap-3 rounded-md px-2 py-2 hover:bg-[--sidebar-accent] transition-colors duration-150 cursor-pointer">
    <div class="flex items-center justify-center w-7 h-7 rounded-full bg-primary text-primary-foreground text-xs font-semibold shrink-0">
      SC
    </div>
    <div data-slot="nav-item-label" class="flex-1 min-w-0">
      <p class="text-sm font-medium text-[--sidebar-foreground] truncate">Steve Clarke</p>
      <p class="text-xs text-[--sidebar-foreground]/50 truncate">steve@example.com</p>
    </div>
    <%= kiso_icon("chevrons-up-down", class: "size-3.5 shrink-0 text-[--sidebar-foreground]/40") %>
  </div>
</div>
