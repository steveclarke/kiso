<%# Sidebar header: logo + app name %>
<div class="flex items-center gap-2.5 px-4 shrink-0 border-b border-[--sidebar-border]"
     style="height: var(--topbar-height)">

  <%# X close button — mobile only %>
  <button data-action="click->kiso--sidebar#toggle"
          aria-label="Close sidebar"
          class="md:hidden flex items-center justify-center w-7 h-7 rounded-md text-[--sidebar-foreground]/50 hover:text-[--sidebar-foreground] hover:bg-[--sidebar-accent] transition-colors duration-150 shrink-0 -ml-1 mr-0.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
    </svg>
  </button>

  <div class="flex items-center justify-center w-6 h-6 rounded-md bg-primary shrink-0">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground" aria-hidden="true">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
    </svg>
  </div>
  <span data-slot="nav-item-label" class="font-semibold text-sm text-[--sidebar-foreground] truncate">
    Kiso App
  </span>
</div>

<%# Navigation sections %>
<div class="flex-1 overflow-y-auto py-3 px-2 space-y-5">

  <%# Platform section %>
  <div data-slot="nav-section">
    <p data-slot="nav-section-title"
       class="px-3 mb-1 text-[11px] font-semibold uppercase tracking-widest text-[--sidebar-foreground]/40 truncate">
      Platform
    </p>

    <a href="/dashboard"
       data-slot="nav-item"
       aria-current="page"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              aria-[current=page]:bg-[--sidebar-accent] aria-[current=page]:text-primary
              transition-colors duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70 group-aria-[current=page]:opacity-100" aria-hidden="true">
        <rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>
      </svg>
      <span data-slot="nav-item-label" class="truncate">Dashboard</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70" aria-hidden="true">
        <line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/>
      </svg>
      <span data-slot="nav-item-label" class="truncate">Analytics</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70" aria-hidden="true">
        <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
      </svg>
      <span data-slot="nav-item-label" class="truncate">Projects</span>
      <%= kui(:badge, color: :primary, variant: :soft, size: :sm) { "4" } %>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70" aria-hidden="true">
        <path d="M11 12H3"/><path d="M16 6H3"/><path d="M16 18H3"/><path d="m19 10-4 4 4 4"/>
      </svg>
      <span data-slot="nav-item-label" class="truncate">Tasks</span>
    </a>
  </div>

  <%# Manage section %>
  <div data-slot="nav-section">
    <p data-slot="nav-section-title"
       class="px-3 mb-1 text-[11px] font-semibold uppercase tracking-widest text-[--sidebar-foreground]/40 truncate">
      Manage
    </p>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70" aria-hidden="true">
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span data-slot="nav-item-label" class="truncate">Team</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70" aria-hidden="true">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>
      </svg>
      <span data-slot="nav-item-label" class="truncate">Settings</span>
    </a>

    <a href="#"
       data-slot="nav-item"
       class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium
              text-[--sidebar-foreground] hover:bg-[--sidebar-accent] hover:text-[--sidebar-accent-foreground]
              transition-colors duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70" aria-hidden="true">
        <rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>
      </svg>
      <span data-slot="nav-item-label" class="truncate">Billing</span>
    </a>
  </div>
</div>

<%# Theme selector %>
<div class="shrink-0 px-4 py-3 border-t border-[--sidebar-border]">
  <p class="px-1 mb-1.5 text-[11px] font-semibold uppercase tracking-widest text-[--sidebar-foreground]/40">Theme</p>
  <%= kui(:color_mode_select, size: :sm) %>
</div>

<%# Sidebar footer: user profile %>
<div class="shrink-0 p-3 border-t border-[--sidebar-border]">
  <div class="flex items-center gap-3 rounded-md px-2 py-2 hover:bg-[--sidebar-accent] transition-colors duration-150 cursor-pointer">
    <div class="flex items-center justify-center w-7 h-7 rounded-full bg-primary text-primary-foreground text-xs font-semibold shrink-0">
      SC
    </div>
    <div data-slot="nav-item-label" class="flex-1 min-w-0">
      <p class="text-sm font-medium text-[--sidebar-foreground] truncate">Steve Clarke</p>
      <p class="text-xs text-[--sidebar-foreground]/50 truncate">steve@example.com</p>
    </div>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[--sidebar-foreground]/40" aria-hidden="true">
      <path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/>
    </svg>
  </div>
</div>
