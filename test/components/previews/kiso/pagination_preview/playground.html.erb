<%
  # Build a series like Pagy would: [1, :gap, prev, current, next, :gap, total]
  series = []
  if total_pages <= 7
    series = (1..total_pages).to_a
  else
    series = [1]
    series << :gap if current_page > 3
    ((current_page - 1)..(current_page + 1)).each do |p|
      series << p if p > 1 && p < total_pages
    end
    series << :gap if current_page < total_pages - 2
    series << total_pages
  end
%>
<%= kui(:pagination) do %>
  <%= kui(:pagination, :content) do %>
    <%= kui(:pagination, :item) { kui(:pagination, :previous, href: current_page > 1 ? "#" : nil) } %>
    <% series.each do |item| %>
      <% if item == :gap %>
        <%= kui(:pagination, :item) { kui(:pagination, :ellipsis) } %>
      <% else %>
        <%= kui(:pagination, :item) do %>
          <%= kui(:pagination, :link, href: "#", active: item == current_page) { item.to_s } %>
        <% end %>
      <% end %>
    <% end %>
    <%= kui(:pagination, :item) { kui(:pagination, :next, href: current_page < total_pages ? "#" : nil) } %>
  <% end %>
<% end %>
