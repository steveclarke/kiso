<%# Few pages (no ellipsis needed): 1 2 [3] 4 5 %>
<%= kiso(:pagination) do %>
  <%= kiso(:pagination_content) do %>
    <%= kiso(:pagination_previous, href: "#") %>
    <%= kiso(:pagination_item) { kiso(:pagination_link, href: "#") { "1" } } %>
    <%= kiso(:pagination_item) { kiso(:pagination_link, href: "#") { "2" } } %>
    <%= kiso(:pagination_item) { kiso(:pagination_link, href: "#", active: true) { "3" } } %>
    <%= kiso(:pagination_item) { kiso(:pagination_link, href: "#") { "4" } } %>
    <%= kiso(:pagination_item) { kiso(:pagination_link, href: "#") { "5" } } %>
    <%= kiso(:pagination_next, href: "#") %>
  <% end %>
<% end %>
