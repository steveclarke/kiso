<div class="flex flex-col gap-4 text-foreground">
  <%= kui(:radio_group) do %>
    <div class="flex items-center gap-3">
      <%= kui(:radio_group, :item, value: "enabled", name: :status, id: :status_enabled, checked: true) %>
      <label for="status_enabled" class="text-sm">Enabled (selected)</label>
    </div>
    <div class="flex items-center gap-3">
      <%= kui(:radio_group, :item, value: "disabled_unchecked", name: :status, id: :status_disabled_unchecked, disabled: true) %>
      <label for="status_disabled_unchecked" class="text-sm text-muted-foreground">Disabled unchecked</label>
    </div>
    <div class="flex items-center gap-3">
      <%= kui(:radio_group, :item, value: "disabled_checked", name: :disabled_demo, id: :status_disabled_checked, disabled: true, checked: true) %>
      <label for="status_disabled_checked" class="text-sm text-muted-foreground">Disabled checked</label>
    </div>
  <% end %>
</div>
