<div class="flex flex-wrap gap-2 items-center text-foreground">
  <%= kui(:toggle, variant: :outline, "aria-label": "Toggle italic") do %>
    <%= kiso_icon("italic") %>
    Italic
  <% end %>
  <%= kui(:toggle, variant: :outline, "aria-label": "Toggle bold") do %>
    <%= kiso_icon("bold") %>
    Bold
  <% end %>
</div>
