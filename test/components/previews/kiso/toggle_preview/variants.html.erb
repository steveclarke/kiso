<div class="space-y-4 text-foreground">
  <div>
    <p class="text-sm text-muted-foreground mb-2">Default</p>
    <div class="flex gap-3 items-center">
      <%= kui(:toggle, "aria-label": "Toggle bold") do %>
        <%= kiso_icon("bold") %>
      <% end %>
      <%= kui(:toggle, pressed: true, "aria-label": "Toggle italic") do %>
        <%= kiso_icon("italic") %>
      <% end %>
    </div>
  </div>

  <div>
    <p class="text-sm text-muted-foreground mb-2">Outline</p>
    <div class="flex gap-3 items-center">
      <%= kui(:toggle, variant: :outline, "aria-label": "Toggle bold") do %>
        <%= kiso_icon("bold") %>
      <% end %>
      <%= kui(:toggle, variant: :outline, pressed: true, "aria-label": "Toggle italic") do %>
        <%= kiso_icon("italic") %>
      <% end %>
    </div>
  </div>
</div>
