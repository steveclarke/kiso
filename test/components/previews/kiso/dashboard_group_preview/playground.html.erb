<%# Full dashboard layout composition at reduced scale for Lookbook preview %>
<div class="w-full overflow-hidden rounded-lg border border-border" style="height: 480px;">
  <%= kui(:dashboard_group, sidebar_open: true) do %>
    <%= kui(:dashboard_navbar) do %>
      <%= kui(:dashboard_sidebar, :toggle) %>
      <%= kui(:dashboard_sidebar, :collapse) %>
      <span class="text-sm font-semibold text-foreground">Dashboard</span>
      <div class="ml-auto flex items-center gap-2">
        <button class="flex items-center justify-center w-7 h-7 rounded-full bg-primary text-primary-foreground text-xs font-semibold shrink-0" type="button">
          SC
        </button>
      </div>
    <% end %>

    <%= kui(:dashboard_sidebar) do %>
      <div class="flex items-center gap-2.5 px-4 shrink-0 border-b border-[--sidebar-border]"
           style="height: var(--topbar-height)">
        <div class="flex items-center justify-center w-6 h-6 rounded-md bg-primary shrink-0">
          <%= kiso_icon("layers", class: "size-3.5 text-primary-foreground") %>
        </div>
        <span class="font-semibold text-sm truncate">Kiso App</span>
      </div>
      <%= kui(:nav) do %>
        <%= kui(:nav, :section, title: "Main") do %>
          <%= kui(:nav, :item, href: "#", icon: "layout-dashboard", active: true) { "Dashboard" } %>
          <%= kui(:nav, :item, href: "#", icon: "bar-chart-3") { "Analytics" } %>
          <%= kui(:nav, :item, href: "#", icon: "users", badge: "3") { "Team" } %>
        <% end %>
        <%= kui(:nav, :section, title: "Settings") do %>
          <%= kui(:nav, :item, href: "#", icon: "settings") { "General" } %>
          <%= kui(:nav, :item, href: "#", icon: "credit-card") { "Billing" } %>
        <% end %>
      <% end %>
    <% end %>

    <%= kui(:dashboard_panel) do %>
      <%= kui(:dashboard_toolbar) do %>
        <%= kui(:dashboard_toolbar, :left) do %>
          <%= kui(:breadcrumb) do %>
            <%= kui(:breadcrumb, :list) do %>
              <%= kui(:breadcrumb, :item) do %>
                <%= kui(:breadcrumb, :link, href: "#") { "Home" } %>
              <% end %>
              <%= kui(:breadcrumb, :separator) %>
              <%= kui(:breadcrumb, :item) do %>
                <%= kui(:breadcrumb, :page) { "Dashboard" } %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
        <%= kui(:dashboard_toolbar, :right) do %>
          <%= kui(:button, size: :sm, variant: :outline) { "Export" } %>
        <% end %>
      <% end %>
      <div class="p-6 space-y-4">
        <div>
          <h1 class="text-xl font-bold tracking-tight">Overview</h1>
          <p class="text-muted-foreground text-sm mt-0.5">Your key metrics at a glance.</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <%= kui(:stats_card) do %>
            <%= kui(:stats_card, :header) { kui(:stats_card, :label) { "Revenue" } } %>
            <%= kui(:stats_card, :value) { "$47,821" } %>
            <%= kui(:stats_card, :description) { "↑ 12.5% from last month" } %>
          <% end %>
          <%= kui(:stats_card) do %>
            <%= kui(:stats_card, :header) { kui(:stats_card, :label) { "Users" } } %>
            <%= kui(:stats_card, :value) { "2,847" } %>
            <%= kui(:stats_card, :description) { "↑ 8.2% from last month" } %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
