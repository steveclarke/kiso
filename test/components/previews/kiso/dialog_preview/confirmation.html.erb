<%= kui(:button, color: :error,
    onclick: "document.getElementById('confirm-dialog').showModal()") { "Delete Account" } %>

<%= kui(:dialog, id: "confirm-dialog") do %>
  <%= kui(:dialog, :header) do %>
    <%= kui(:dialog, :title) { "Are you sure?" } %>
    <%= kui(:dialog, :description) { "This action cannot be undone. This will permanently delete your account and remove your data from our servers." } %>
  <% end %>
  <%= kui(:dialog, :footer) do %>
    <%= kui(:button, variant: :outline, data: { action: "kiso--dialog#close" }) { "Cancel" } %>
    <%= kui(:button, color: :error) { "Delete account" } %>
  <% end %>
<% end %>
