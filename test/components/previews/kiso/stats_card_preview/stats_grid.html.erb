<%= kui(:stats_grid, columns: 4) do %>
  <%= kui(:stats_card) do %>
    <%= kui(:stats_card, :header) do %>
      <%= kui(:stats_card, :label) { "Total Revenue" } %>
      <%= kiso_icon("dollar-sign", class: "size-4 text-muted-foreground") %>
    <% end %>
    <%= kui(:stats_card, :value) { "$45,231.89" } %>
    <%= kui(:stats_card, :description) { "+20.1% from last month" } %>
  <% end %>

  <%= kui(:stats_card) do %>
    <%= kui(:stats_card, :header) do %>
      <%= kui(:stats_card, :label) { "Subscriptions" } %>
      <%= kiso_icon("users", class: "size-4 text-muted-foreground") %>
    <% end %>
    <%= kui(:stats_card, :value) { "+2,350" } %>
    <%= kui(:stats_card, :description) { "+180.1% from last month" } %>
  <% end %>

  <%= kui(:stats_card) do %>
    <%= kui(:stats_card, :header) do %>
      <%= kui(:stats_card, :label) { "Active Now" } %>
      <%= kiso_icon("activity", class: "size-4 text-muted-foreground") %>
    <% end %>
    <%= kui(:stats_card, :value) { "+573" } %>
    <%= kui(:stats_card, :description) { "+201 since last hour" } %>
  <% end %>

  <%= kui(:stats_card) do %>
    <%= kui(:stats_card, :header) do %>
      <%= kui(:stats_card, :label) { "Growth Rate" } %>
      <%= kiso_icon("trending-up", class: "size-4 text-muted-foreground") %>
    <% end %>
    <%= kui(:stats_card, :value) { "4.5%" } %>
    <%= kui(:stats_card, :description) { "+0.5% from last quarter" } %>
  <% end %>
<% end %>
