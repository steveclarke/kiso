<div class="space-y-6">
  <div>
    <p class="text-sm text-muted-foreground mb-2">Solid</p>
    <div class="flex flex-wrap gap-3 items-center">
      <%= kui(:badge, color: :primary, variant: :solid) { "Primary" } %>
      <%= kui(:badge, color: :secondary, variant: :solid) { "Secondary" } %>
      <%= kui(:badge, color: :success, variant: :solid) { "Success" } %>
      <%= kui(:badge, color: :info, variant: :solid) { "Info" } %>
      <%= kui(:badge, color: :warning, variant: :solid) { "Warning" } %>
      <%= kui(:badge, color: :error, variant: :solid) { "Error" } %>
      <%= kui(:badge, color: :neutral, variant: :solid) { "Neutral" } %>
    </div>
  </div>

  <div>
    <p class="text-sm text-muted-foreground mb-2">Outline</p>
    <div class="flex flex-wrap gap-3 items-center">
      <%= kui(:badge, color: :primary, variant: :outline) { "Primary" } %>
      <%= kui(:badge, color: :secondary, variant: :outline) { "Secondary" } %>
      <%= kui(:badge, color: :success, variant: :outline) { "Success" } %>
      <%= kui(:badge, color: :info, variant: :outline) { "Info" } %>
      <%= kui(:badge, color: :warning, variant: :outline) { "Warning" } %>
      <%= kui(:badge, color: :error, variant: :outline) { "Error" } %>
      <%= kui(:badge, color: :neutral, variant: :outline) { "Neutral" } %>
    </div>
  </div>

  <div>
    <p class="text-sm text-muted-foreground mb-2">Soft</p>
    <div class="flex flex-wrap gap-3 items-center">
      <%= kui(:badge, color: :primary, variant: :soft) { "Primary" } %>
      <%= kui(:badge, color: :secondary, variant: :soft) { "Secondary" } %>
      <%= kui(:badge, color: :success, variant: :soft) { "Success" } %>
      <%= kui(:badge, color: :info, variant: :soft) { "Info" } %>
      <%= kui(:badge, color: :warning, variant: :soft) { "Warning" } %>
      <%= kui(:badge, color: :error, variant: :soft) { "Error" } %>
      <%= kui(:badge, color: :neutral, variant: :soft) { "Neutral" } %>
    </div>
  </div>

  <div>
    <p class="text-sm text-muted-foreground mb-2">Subtle</p>
    <div class="flex flex-wrap gap-3 items-center">
      <%= kui(:badge, color: :primary, variant: :subtle) { "Primary" } %>
      <%= kui(:badge, color: :secondary, variant: :subtle) { "Secondary" } %>
      <%= kui(:badge, color: :success, variant: :subtle) { "Success" } %>
      <%= kui(:badge, color: :info, variant: :subtle) { "Info" } %>
      <%= kui(:badge, color: :warning, variant: :subtle) { "Warning" } %>
      <%= kui(:badge, color: :error, variant: :subtle) { "Error" } %>
      <%= kui(:badge, color: :neutral, variant: :subtle) { "Neutral" } %>
    </div>
  </div>
</div>
