<div class="max-w-sm space-y-4">
  <%# Both prefix and suffix %>
  <%= kui(:input_group) do %>
    <%= kui(:input_group, :addon) { "$" } %>
    <%= kui(:input, type: :number, placeholder: "0.00") %>
    <%= kui(:input_group, :addon, align: :end) { "USD" } %>
  <% end %>

  <%# Icon prefix and text suffix %>
  <%= kui(:input_group) do %>
    <%= kui(:input_group, :addon) do %>
      <%= kiso_icon("search", class: "size-4") %>
    <% end %>
    <%= kui(:input, type: :text, placeholder: "Search...") %>
    <%= kui(:input_group, :addon, align: :end) do %>
      <%= kui(:kbd) { "⌘K" } %>
    <% end %>
  <% end %>
</div>
