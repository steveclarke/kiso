<div class="max-w-sm">
  <%= kui(:field) do %>
    <%= kui(:field, :label, for: :department) { "Department" } %>
    <%= kui(:select, name: :department) do %>
      <%= kui(:select, :trigger) do %>
        <%= kui(:select, :value, placeholder: "Select a department") %>
      <% end %>
      <%= kui(:select, :content) do %>
        <%= kui(:select, :group) do %>
          <%= kui(:select, :item, value: "engineering") { "Engineering" } %>
          <%= kui(:select, :item, value: "design") { "Design" } %>
          <%= kui(:select, :item, value: "marketing") { "Marketing" } %>
          <%= kui(:select, :item, value: "sales") { "Sales" } %>
        <% end %>
      <% end %>
    <% end %>
    <%= kui(:field, :description) { "This determines your team assignment and access level." } %>
  <% end %>
</div>
