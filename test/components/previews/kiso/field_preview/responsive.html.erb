<div class="max-w-2xl">
  <%= kui(:field_set) do %>
    <%= kui(:field_set, :legend) { "Profile" } %>
    <%= kui(:field, :description) { "This information will be displayed on your public profile." } %>

    <%= kui(:field_group) do %>
      <%= kui(:field, orientation: :responsive) do %>
        <%= kui(:field, :label, for: :resp_name) { "Full name" } %>
        <%= kui(:input, id: :resp_name, name: :name, placeholder: "Evil Rabbit") %>
      <% end %>

      <%= kui(:field, orientation: :responsive) do %>
        <%= kui(:field, :label, for: :resp_email) { "Email" } %>
        <%= kui(:field, :content) do %>
          <%= kui(:input, type: :email, id: :resp_email, name: :email, placeholder: "evil@rabbit.com") %>
          <%= kui(:field, :description) { "This will be visible to other members." } %>
        <% end %>
      <% end %>

      <%= kui(:field, orientation: :responsive) do %>
        <%= kui(:field, :label, for: :resp_bio) { "Bio" } %>
        <%= kui(:field, :content) do %>
          <%= kui(:textarea, id: :resp_bio, name: :bio, rows: 3, placeholder: "Tell us about yourself...") %>
          <%= kui(:field, :description) { "You can use markdown for formatting." } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
