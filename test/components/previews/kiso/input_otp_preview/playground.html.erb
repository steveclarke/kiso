<div class="flex items-center justify-center py-10">
  <%= kui(:input_otp, length: length, name: "otp", disabled: disabled, aria_label: "One-time password") do %>
    <%= kui(:input_otp, :group) do %>
      <% 3.times do %>
        <%= kui(:input_otp, :slot, size: size) %>
      <% end %>
    <% end %>
    <%= kui(:input_otp, :separator) %>
    <%= kui(:input_otp, :group) do %>
      <% 3.times do %>
        <%= kui(:input_otp, :slot, size: size) %>
      <% end %>
    <% end %>
  <% end %>
</div>
