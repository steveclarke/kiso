<div class="flex items-center justify-center py-10">
  <%= kui(:input_otp, length: 6, name: "otp", disabled: true, value: "123456", aria_label: "One-time password") do %>
    <%= kui(:input_otp, :group) do %>
      <% 3.times do %>
        <%= kui(:input_otp, :slot) %>
      <% end %>
    <% end %>
    <%= kui(:input_otp, :separator) %>
    <%= kui(:input_otp, :group) do %>
      <% 3.times do %>
        <%= kui(:input_otp, :slot) %>
      <% end %>
    <% end %>
  <% end %>
</div>
