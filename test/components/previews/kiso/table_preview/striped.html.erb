<%= kui(:table) do %>
  <%= kui(:table, :header) do %>
    <%= kui(:table, :row) do %>
      <%= kui(:table, :head) { "Name" } %>
      <%= kui(:table, :head) { "Email" } %>
      <%= kui(:table, :head) { "Role" } %>
    <% end %>
  <% end %>
  <%= kui(:table, :body) do %>
    <% [
      { name: "Alice Johnson", email: "alice@example.com", role: "Admin" },
      { name: "Bob Smith", email: "bob@example.com", role: "Editor" },
      { name: "Carol White", email: "carol@example.com", role: "Viewer" },
      { name: "Dave Brown", email: "dave@example.com", role: "Editor" },
      { name: "Eve Davis", email: "eve@example.com", role: "Admin" },
    ].each_with_index do |row, i| %>
      <%= kui(:table, :row, css_classes: i.even? ? "bg-muted/25" : "") do %>
        <%= kui(:table, :cell, css_classes: "font-medium") { row[:name] } %>
        <%= kui(:table, :cell) { row[:email] } %>
        <%= kui(:table, :cell) { row[:role] } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
