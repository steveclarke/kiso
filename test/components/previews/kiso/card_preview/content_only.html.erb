<div class="max-w-sm p-8">
  <%= kiso(:card) do %>
    <%= kiso(:card, :content) do %>
      <p class="text-sm text-muted-foreground">
        A simple card with only a content section. The card's <code class="text-foreground">gap-6</code> and
        <code class="text-foreground">py-6</code> handle vertical spacing automatically.
      </p>
    <% end %>
  <% end %>
</div>
