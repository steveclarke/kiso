<div class="max-w-sm">
  <%= kui(:card) do %>
    <%= kui(:card, :header) do %>
      <%= kui(:card, :title) { "Notifications" } %>
      <%= kui(:card, :description) { "You have 3 unread messages." } %>
      <%= kui(:card, :action) do %>
        <%= kui(:badge, variant: :outline) { "Featured" } %>
      <% end %>
    <% end %>
    <%= kui(:card, :content) do %>
      <p class="text-sm text-muted-foreground">
        Your notifications will appear here.
      </p>
    <% end %>
  <% end %>
</div>
