<div class="max-w-sm space-y-6 p-8">
  <% %i[outline soft subtle].each do |variant| %>
    <%= kiso(:card, variant: variant) do %>
      <%= kiso(:card, :header) do %>
        <%= kiso(:card, :title) { variant.to_s.capitalize } %>
        <%= kiso(:card, :description) { "This card uses the #{variant} variant." } %>
      <% end %>
      <%= kiso(:card, :content) do %>
        <p class="text-sm text-muted-foreground">Card content area.</p>
      <% end %>
    <% end %>
  <% end %>
</div>
