<div class="max-w-lg space-y-6">
  <% %i[solid outline soft subtle].each do |variant| %>
    <div>
      <p class="text-sm text-muted-foreground mb-2"><%= variant.to_s.capitalize %></p>
      <div class="space-y-3">
        <% %i[primary secondary success info warning error neutral].each do |color| %>
          <%= kui(:alert, color: color, variant: variant) do %>
            <%= kui(:alert, :title) { color.to_s.capitalize } %>
            <%= kui(:alert, :description) { "This is a #{color} #{variant} alert." } %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
