<div class="text-foreground">
  <%= kui(:collapsible, open: open, css_classes: "flex w-[350px] flex-col gap-2") do %>
    <div class="flex items-center justify-between gap-4 px-4">
      <h4 class="text-sm font-semibold">Order #4189</h4>
      <%= kui(:button, variant: :ghost, size: :icon, css_classes: "size-8",
            data: { action: "kiso--collapsible#toggle",
                    kiso__collapsible_target: "trigger" }) do %>
        <%= kiso_icon("chevrons-up-down") %>
        <span class="sr-only">Toggle details</span>
      <% end %>
    </div>
    <div class="flex items-center justify-between rounded-md ring ring-inset ring-border px-4 py-2 text-sm">
      <span class="text-muted-foreground">Status</span>
      <span class="font-medium">Shipped</span>
    </div>
    <%= kui(:collapsible, :content, css_classes: "flex flex-col gap-2") do %>
      <div class="rounded-md ring ring-inset ring-border px-4 py-2 text-sm">
        <p class="font-medium">Shipping address</p>
        <p class="text-muted-foreground">100 Market St, San Francisco</p>
      </div>
      <div class="rounded-md ring ring-inset ring-border px-4 py-2 text-sm">
        <p class="font-medium">Items</p>
        <p class="text-muted-foreground">2x Studio Headphones</p>
      </div>
    <% end %>
  <% end %>
</div>
