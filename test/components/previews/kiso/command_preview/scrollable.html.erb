<div class="text-foreground">
  <%= kui(:command, css_classes: "max-w-sm rounded-lg ring ring-inset ring-border") do %>
    <%= kui(:command, :input, placeholder: "Type a command or search...") %>
    <%= kui(:command, :list) do %>
      <%= kui(:command, :empty) { "No results found." } %>
      <%= kui(:command, :group, heading: "Navigation") do %>
        <%= kui(:command, :item, value: "home") do %>
          <%= kiso_icon("house") %>
          <span>Home</span>
          <%= kui(:command, :shortcut) { "⌘H" } %>
        <% end %>
        <%= kui(:command, :item, value: "inbox") do %>
          <%= kiso_icon("inbox") %>
          <span>Inbox</span>
          <%= kui(:command, :shortcut) { "⌘I" } %>
        <% end %>
        <%= kui(:command, :item, value: "documents") do %>
          <%= kiso_icon("file-text") %>
          <span>Documents</span>
          <%= kui(:command, :shortcut) { "⌘D" } %>
        <% end %>
        <%= kui(:command, :item, value: "folders") do %>
          <%= kiso_icon("folder") %>
          <span>Folders</span>
          <%= kui(:command, :shortcut) { "⌘F" } %>
        <% end %>
      <% end %>
      <%= kui(:command, :separator) %>
      <%= kui(:command, :group, heading: "Actions") do %>
        <%= kui(:command, :item, value: "new-file") do %>
          <%= kiso_icon("plus") %>
          <span>New File</span>
          <%= kui(:command, :shortcut) { "⌘N" } %>
        <% end %>
        <%= kui(:command, :item, value: "new-folder") do %>
          <%= kiso_icon("folder-plus") %>
          <span>New Folder</span>
          <%= kui(:command, :shortcut) { "⇧⌘N" } %>
        <% end %>
        <%= kui(:command, :item, value: "copy") do %>
          <%= kiso_icon("copy") %>
          <span>Copy</span>
          <%= kui(:command, :shortcut) { "⌘C" } %>
        <% end %>
        <%= kui(:command, :item, value: "cut") do %>
          <%= kiso_icon("scissors") %>
          <span>Cut</span>
          <%= kui(:command, :shortcut) { "⌘X" } %>
        <% end %>
        <%= kui(:command, :item, value: "paste") do %>
          <%= kiso_icon("clipboard-paste") %>
          <span>Paste</span>
          <%= kui(:command, :shortcut) { "⌘V" } %>
        <% end %>
        <%= kui(:command, :item, value: "delete") do %>
          <%= kiso_icon("trash") %>
          <span>Delete</span>
          <%= kui(:command, :shortcut) { "⌫" } %>
        <% end %>
      <% end %>
      <%= kui(:command, :separator) %>
      <%= kui(:command, :group, heading: "Account") do %>
        <%= kui(:command, :item, value: "profile") do %>
          <%= kiso_icon("user") %>
          <span>Profile</span>
          <%= kui(:command, :shortcut) { "⌘P" } %>
        <% end %>
        <%= kui(:command, :item, value: "billing") do %>
          <%= kiso_icon("credit-card") %>
          <span>Billing</span>
          <%= kui(:command, :shortcut) { "⌘B" } %>
        <% end %>
        <%= kui(:command, :item, value: "settings") do %>
          <%= kiso_icon("settings") %>
          <span>Settings</span>
          <%= kui(:command, :shortcut) { "⌘S" } %>
        <% end %>
        <%= kui(:command, :item, value: "notifications") do %>
          <%= kiso_icon("bell") %>
          <span>Notifications</span>
        <% end %>
        <%= kui(:command, :item, value: "help") do %>
          <%= kiso_icon("circle-help") %>
          <span>Help & Support</span>
        <% end %>
      <% end %>
      <%= kui(:command, :separator) %>
      <%= kui(:command, :group, heading: "Tools") do %>
        <%= kui(:command, :item, value: "calculator") do %>
          <%= kiso_icon("calculator") %>
          <span>Calculator</span>
        <% end %>
        <%= kui(:command, :item, value: "calendar") do %>
          <%= kiso_icon("calendar") %>
          <span>Calendar</span>
        <% end %>
        <%= kui(:command, :item, value: "image-editor") do %>
          <%= kiso_icon("image") %>
          <span>Image Editor</span>
        <% end %>
        <%= kui(:command, :item, value: "code-editor") do %>
          <%= kiso_icon("code") %>
          <span>Code Editor</span>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
