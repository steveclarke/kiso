<div class="space-y-4">
  <p class="text-sm text-muted-foreground">Leading icon</p>
  <div class="flex flex-wrap gap-3 items-center">
    <%= kui(:button) do %>
      <%= kiso_icon("plus") %>
      Add Item
    <% end %>

    <%= kui(:button, variant: :outline) do %>
      <%= kiso_icon("download") %>
      Download
    <% end %>

    <%= kui(:button, variant: :soft) do %>
      <%= kiso_icon("refresh-cw") %>
      Refresh
    <% end %>

    <%= kui(:button, variant: :ghost) do %>
      <%= kiso_icon("x") %>
      Close
    <% end %>
  </div>

  <p class="text-sm text-muted-foreground">Icon auto-sizing per button size</p>
  <div class="flex gap-3 items-end">
    <% %i[xs sm md lg xl].each do |size| %>
      <%= kui(:button, size: size, variant: :outline) do %>
        <%= kiso_icon("circle-plus") %>
        <%= size.to_s.upcase %>
      <% end %>
    <% end %>
  </div>
</div>
