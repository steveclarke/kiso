---
layout: default
---

<div data-controller="sidebar">
  <%# --- Navbar --- %>
  <%= render Shared::Navbar.new(metadata: site.metadata, resource: resource) %>

  <%# --- Mobile backdrop --- %>
  <div data-sidebar-target="backdrop"
       data-action="click->sidebar#close"
       class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm hidden lg:hidden"></div>

  <div class="flex">
    <%# --- Sidebar --- %>
    <aside data-sidebar-target="panel"
           class="fixed top-14 z-40 h-[calc(100vh-3.5rem)] w-64 shrink-0 overflow-y-auto border-r border-sidebar-border bg-sidebar
                  -translate-x-full lg:translate-x-0 transition-transform duration-200">
      <%= render "sidebar", navigation: site.data.navigation, resource: resource %>
    </aside>

    <%# --- Main content --- %>
    <main class="min-w-0 flex-1 lg:pl-64">
      <div class="mx-auto max-w-3xl px-6 py-10">
        <% if data.title %>
          <h1 class="mb-2 text-3xl font-bold tracking-tight"><%= data.title %></h1>
          <% if data.description %>
            <p class="mb-8 text-lg text-muted-foreground"><%= data.description %></p>
          <% end %>
        <% end %>

        <div class="prose dark:prose-invert max-w-none">
          <%= yield %>
        </div>
      </div>

      <%= render "footer" %>
    </main>
  </div>
</div>
