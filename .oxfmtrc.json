{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": {},
  "sortTailwindcss": {},
  "ignorePatterns": [
    "vendor/**",
    "node_modules/**",
    "docs/**",
    "project/**",
    ".claude/**",
    "skills/**",
    "*.md",
    "*.css"
  ]
}
