<%# locals: (placeholder: nil, disabled: false, css_classes: "", **component_options) %>
<input type="text"
       class="<%= Kiso::Themes::ComboboxChipsInput.render(class: css_classes) %>"
       placeholder="<%= placeholder %>"
       autocomplete="off"
       <% if disabled %>disabled<% end %>
       data-slot="combobox-chips-input"
       data-kiso--combobox-target="input"
       data-action="input->kiso--combobox#filter focus->kiso--combobox#onInputFocus keydown->kiso--combobox#inputKeydown">
